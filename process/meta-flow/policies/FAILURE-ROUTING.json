{
  "routes": {
    "block_release": {
      "creates": [
        "release_blocker"
      ],
      "description": "发布阻断，不能进入 READY / READY_WITH_RISK。",
      "invalidates": [
        "CP8_release_context"
      ],
      "next_allowed_stage": "blocked",
      "updates": [
        "GATE-LEDGER",
        "CHECKPOINT-LEDGER"
      ]
    },
    "create_followup_candidate": {
      "creates": [
        "followup_candidate"
      ],
      "description": "当前交付可收敛，但剩余问题必须进入 follow-up candidate，不自动创建正式 CR。",
      "invalidates": [],
      "next_allowed_stage": "CP8",
      "updates": [
        "CR-LEDGER"
      ]
    },
    "escalate_runtime_high_risk": {
      "creates": [
        "runtime_authorization_decision_item"
      ],
      "description": "触碰 runtime / credential / trading / publish 等边界，强制升级高风险门禁。",
      "invalidates": [
        "current_gate_profile",
        "current_context_pack"
      ],
      "next_allowed_stage": "CP3",
      "updates": [
        "GATE-LEDGER",
        "AUTHZ policy refs"
      ]
    },
    "reopen_cp5_design": {
      "creates": [
        "question_ledger_entry",
        "design_delta_or_lld_update"
      ],
      "description": "失败来自 Story 设计证据不足或契约不清，回到 CP5 设计证据。",
      "invalidates": [
        "CP6_packet",
        "CP7_packet",
        "current_cp_result"
      ],
      "next_allowed_stage": "CP5",
      "updates": [
        "STORY-LEDGER",
        "QUESTION-LEDGER"
      ]
    },
    "require_user_decision": {
      "creates": [
        "human_decision_item"
      ],
      "description": "需要用户确认 scope/security/runtime/risk decision 后才能继续。",
      "invalidates": [
        "current_cp_result"
      ],
      "next_allowed_stage": "human_gate",
      "updates": [
        "GATE-LEDGER"
      ]
    },
    "rework_same_story": {
      "creates": [
        "rework_packet"
      ],
      "description": "实现或验证失败，但 Story 范围仍然成立，回到同一 Story 的 CP6/CP7 返工。",
      "invalidates": [
        "current_cp_result",
        "downstream_verify_packet"
      ],
      "next_allowed_stage": "CP6",
      "updates": [
        "STORY-LEDGER"
      ]
    },
    "waive_with_risk_acceptance": {
      "creates": [
        "waiver_record",
        "risk_acceptance_item"
      ],
      "description": "可豁免检查项，但必须有 scope / expiry / approval_ref，并强制风险接受状态。",
      "invalidates": [],
      "next_allowed_stage": "CP8",
      "updates": [
        "GATE-LEDGER",
        "CHECKPOINT-LEDGER"
      ]
    }
  },
  "schema_version": 1,
  "severity_route_requirements": {
    "BLOCKER": "required",
    "HIGH": "required",
    "INFO": "optional",
    "LOW": "optional",
    "MEDIUM": "recommended"
  }
}
